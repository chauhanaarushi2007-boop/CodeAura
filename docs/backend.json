
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile information.",
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "The URL of the user's profile picture."
        },
        "isAdmin": {
            "type": "boolean",
            "description": "Whether the user has administrative privileges."
        }
      },
      "required": [
        "displayName",
        "email"
      ]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "Represents a user's feedback submission.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the user providing feedback."
        },
        "message": {
          "type": "string",
          "description": "The feedback message."
        },
        "rating": {
          "type": "number",
          "description": "A star rating from 1 to 5."
        },
        "sentiment": {
          "type": "string",
          "description": "AI-analyzed sentiment (Positive, Negative, Neutral).",
          "enum": ["Positive", "Negative", "Neutral"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The server timestamp when the feedback was created."
        }
      },
      "required": [
        "name",
        "message",
        "rating",
        "createdAt"
      ]
    }
  },
  "auth": {
    "providers": ["Google", "EmailPassword"]
  },
  "firestore": {
    "/users/{userId}": {
        "schema": {
            "$ref": "#/backend/entities/UserProfile"
        },
        "description": "Stores public profile information for users."
    },
    "/feedback/{feedbackId}": {
        "schema": {
            "$ref": "#/backend/entities/Feedback"
        },
        "description": "Stores user feedback submissions."
    }
  }
}
