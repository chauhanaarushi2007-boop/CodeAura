
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile information.",
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "The URL of the user's profile picture."
        },
        "isAdmin": {
            "type": "boolean",
            "description": "Whether the user has administrative privileges."
        }
      },
      "required": [
        "displayName",
        "email"
      ]
    },
    "Review": {
        "title": "User Review",
        "description": "A user-submitted review of the website.",
        "type": "object",
        "properties": {
            "name": {
                "type": "string",
                "description": "The name of the user leaving the review."
            },
            "message": {
                "type": "string",
                "description": "The content of the review."
            },
            "rating": {
                "type": "number",
                "description": "A star rating from 1 to 5."
            },
            "sentiment": {
                "type": "string",
                "enum": ["Positive", "Negative", "Neutral"],
                "description": "The AI-analyzed sentiment of the review."
            },
            "createdAt": {
                "type": "string",
                "format": "date-time",
                "description": "The timestamp when the review was created."
            }
        },
        "required": ["name", "message", "rating", "createdAt"]
    }
  },
  "auth": {
    "providers": ["Google", "EmailPassword"]
  },
  "firestore": {
    "/users/{userId}": {
        "schema": {
            "$ref": "#/backend/entities/UserProfile"
        },
        "description": "Stores public profile information for users."
    },
    "/reviews/{reviewId}": {
        "schema": {
            "$ref": "#/backend/entities/Review"
        },
        "description": "Stores user-submitted reviews for the website."
    }
  }
}
